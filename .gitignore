# .gitignore

# dependencies
/node_modules

# next
/.next
/out

# build
/dist
/coverage

# capacitor / native builds
ios/App/build
ios/build
android/app/build
android/build

# xcode
DerivedData
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.xcuserdatad
ios/App/App.xcworkspace/xcuserdata
ios/App/App.xcodeproj/xcuserdata

# cocoapods, only relevant if pods are introduced later
ios/App/Pods

# env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# secrets
/secrets/*
!/secrets/.gitkeep
!/secrets/*.enc

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# system
.DS_Store
Thumbs.db

# editors
.vscode/*
!.vscode/extensions.json
.idea

# typescript
*.tsbuildinfo
next-env.d.ts